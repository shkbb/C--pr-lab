@page "{id:int}"
@model Library.Web.Pages.Books.DetailsModel
@{
    ViewData["Title"] = "Деталі книги";
}

<h1>Деталі книги</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">ID</dt>
        <dd class="col-sm-10">@Model.Book.Id</dd>

        <dt class="col-sm-2">Назва</dt>
        <dd class="col-sm-10">@Model.Book.Title</dd>

        <dt class="col-sm-2">Автор</dt>
        <dd class="col-sm-10">@Model.Book.AuthorFullName</dd>

        <dt class="col-sm-2">ISBN</dt>
        <dd class="col-sm-10">@Model.Book.ISBN</dd>

        <dt class="col-sm-2">Жанр</dt>
        <dd class="col-sm-10">@Model.Book.Genre</dd>

        <dt class="col-sm-2">Рік видання</dt>
        <dd class="col-sm-10">@Model.Book.PublishedYear</dd>
    </dl>
</div>
<div>
    <a asp-page="./Index" class="btn btn-secondary">Назад до списку</a>
</div>
